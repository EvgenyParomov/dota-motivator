{
  "name": "@dm/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx/esm dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "migrate:push": "drizzle-kit push"
  },
  "dependencies": {
    "@dm/shared": "workspace:*",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.7",
    "inversify": "^6.0.3",
    "minio": "^8.0.5",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@testcontainers/minio": "^10.16.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.28.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
