{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Dota Motivator",
  "version": "0.0.0",
  "identifier": "dev.dotamotivator.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Dota Motivator",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "opener": {}
  }
}
