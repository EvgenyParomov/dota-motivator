{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Dota Motivator",
  "version": "0.0.11",
  "identifier": "dev.dotamotivator.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Dota Motivator",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "opener": {},
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDQTQzOTEzRjMxMkY1RTMKUldUajlSTHpFem1rL09WMXN3QWhydDFUY2RLcm1NUG9TdmkwYzNmNk9idVNwZjB4cGl2UGJFcE0K",
      "endpoints": [
        "https://github.com/EvgenyParomov/dota-motivator/releases/latest/download/latest.json"
      ]
    }
  }
}
